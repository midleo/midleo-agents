[Unit]
Description=Midleo Actions
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10
 
[Service]
Type=simple
User={{mwuser}}
Group={{mwuser}}
WorkingDirectory={{agent_install_dir}}
Environment=PYTHONUNBUFFERED=1
ExecStart={{python_install_dir}} -u {{agent_install_dir}}midleo_actions.py
Restart=on-failure
RestartSec=10
TimeoutStopSec=30
KillSignal=SIGINT
UMask=0027
LimitNOFILE=65535
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
LockPersonality=true
RestrictSUIDSGID=true
CapabilityBoundingSet=
AmbientCapabilities=
 
[Install]
WantedBy=multi-user.target
